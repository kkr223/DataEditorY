{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DataEditorY Extra",
  "version": "1.2.2",
  "identifier": "com.kkr223.dataeditory.extra",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "DataEditorY Extra",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "../static/resources/strings.conf": "resources/strings.conf",
      "../static/resources/cover.jpg": "resources/cover.jpg",
      "../static/resources/yugioh-card": "resources/yugioh-card"
    },
    "fileAssociations": [
      {
        "ext": [
          "cdb"
        ],
        "name": "YGOPro CDB Database",
        "description": "YGOPro card database file",
        "mimeType": "application/x-ygopro-cdb"
      }
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
