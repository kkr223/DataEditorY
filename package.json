{
  "name": "dataeditory",
  "version": "2.3.0",
  "description": "ygopro card database editor",
  "author": "kkr223",
  "type": "module",
  "scripts": {
    "build:lua-intel": "node scripts/build-lua-intel.mjs",
    "dev:raw": "bun run build:lua-intel && vite dev",
    "dev": "node scripts/run-variant-build.mjs dev-frontend",
    "dev:base": "node scripts/run-variant-build.mjs dev-frontend base",
    "dev:extra": "node scripts/run-variant-build.mjs dev-frontend extra",
    "build:web:raw": "bun run build:lua-intel && svelte-kit sync && vite build && node scripts/remove-build-assets.mjs",
    "build": "node scripts/run-variant-build.mjs frontend",
    "build:base": "node scripts/run-variant-build.mjs frontend base",
    "build:extra": "node scripts/run-variant-build.mjs frontend extra",
    "preview": "vite preview",
    "check": "bun run build:lua-intel && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "bun run build:lua-intel && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test": "bun test",
    "tauri": "node scripts/run-variant-build.mjs tauri",
    "tauri:dev": "node scripts/run-variant-build.mjs tauri dev extra",
    "tauri:dev:base": "node scripts/run-variant-build.mjs tauri dev base",
    "tauri:dev:extra": "node scripts/run-variant-build.mjs tauri dev extra",
    "tauri:build": "node scripts/run-variant-build.mjs tauri build extra",
    "tauri:build:base": "node scripts/run-variant-build.mjs tauri build base",
    "tauri:build:extra": "node scripts/run-variant-build.mjs tauri build extra",
    "tauri:build:all": "node scripts/run-variant-build.mjs build-all"
  },
  "license": "MIT",
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "~2",
    "@tauri-apps/plugin-fs": "~2",
    "@tauri-apps/plugin-opener": "^2",
    "luaparse": "^0.3.1",
    "monaco-editor": "^0.55.1",
    "svelte-i18n": "^4.0.1",
    "yugioh-card": "^1.8.2"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.6",
    "@sveltejs/kit": "^2.9.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tauri-apps/cli": "^2",
    "@types/luaparse": "^0.2.13",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "~5.6.2",
    "vite": "^6.0.3"
  }
}
