  {
    "name": "selectmatchcard",
    "prefix": "#slma",
    "body": [
      "Duel.Hint(HINT_SELECTMSG,tp,HINTMSG_$1)",
      "local g=Duel.SelectMatchingCard(tp,s.$2,tp,$3,$4,1,1,nil$5)"
    ],
    "description": "selectmatchcard",
    "sortText": "1006"
  },
